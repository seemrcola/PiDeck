{
  "name": "pi-desktop",
  "version": "0.4.14",
  "description": "Desktop workbench for managing multiple pi RPC agents across project folders.",
  "private": true,
  "license": "MIT",
  "author": {
    "name": "ayuayue",
    "email": "ayuayue@users.noreply.github.com"
  },
  "homepage": "https://github.com/ayuayue/pi-desktop#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ayuayue/pi-desktop.git"
  },
  "bugs": {
    "url": "https://github.com/ayuayue/pi-desktop/issues"
  },
  "keywords": [
    "pi",
    "coding-agent",
    "electron",
    "desktop",
    "rpc",
    "agent"
  ],
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "tsc --noEmit && electron-vite build",
    "pack": "npm run build && electron-builder --dir",
    "dist": "npm run build && electron-builder",
    "dist:win": "npm run build && electron-builder --win nsis portable zip",
    "dist:mac": "npm run build && electron-builder --mac dmg zip",
    "dist:linux": "npm run build && electron-builder --linux AppImage deb tar.gz",
    "preview": "electron-vite preview",
    "typecheck": "tsc --noEmit",
    "make-icon": "node scripts/make-icon.js"
  },
  "dependencies": {
    "@electron-toolkit/utils": "^4.0.0",
    "node-pty": "^1.1.0"
  },
  "build": {
    "appId": "com.ayuayue.pi-desktop",
    "productName": "pi-desktop",
    "npmRebuild": false,
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "icon": "build/icon",
    "files": [
      "out/**/*",
      "package.json"
    ],
    "extraMetadata": {
      "main": "out/main/index.js"
    },
    "win": {
      "icon": "build/icon.ico",
      "target": [
        "nsis",
        "portable",
        "zip"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "mac": {
      "icon": "build/icon.icns",
      "target": [
        "dmg",
        "zip"
      ],
      "category": "public.app-category.developer-tools"
    },
    "linux": {
      "icon": "build/icons",
      "target": [
        "AppImage",
        "deb",
        "tar.gz"
      ],
      "category": "Development",
      "maintainer": "ayuayue <ayuayue@users.noreply.github.com>"
    }
  },
  "devDependencies": {
    "@electron-toolkit/preload": "^3.0.2",
    "@fiahfy/icns": "^0.0.7",
    "@types/node": "^24.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^5.0.0",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "electron": "^38.0.0",
    "electron-builder": "^26.8.1",
    "electron-vite": "^4.0.0",
    "lucide-react": "^1.17.0",
    "png-to-ico": "^3.0.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "sharp": "^0.34.5",
    "typescript": "^5.9.0",
    "vite": "^7.0.0",
    "zustand": "^5.0.0"
  }
}
